# 失物招领服务 Dockerfile
FROM openjdk:17-jdk-slim

WORKDIR /app

# 设置时区
RUN ln -sf /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && \
    echo 'Asia/Shanghai' > /etc/timezone

# 复制jar包
COPY heikeji-mall-service/service-lostfound/target/service-lostfound-1.0.0.jar /app/lostfound-service.jar

# 创建日志目录
RUN mkdir -p /app/logs

# 设置JVM参数
ENV JAVA_OPTS="-Xms256m -Xmx512m -XX:+UseG1GC -XX:MaxGCPauseMillis=200"
ENV SERVER_PORT=8007

EXPOSE 8007

# 健康检查
HEALTHCHECK --interval=30s --timeout=3s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8007/actuator/health || exit 1

CMD java ${JAVA_OPTS} -jar /app/lostfound-service.jar --server.port=${SERVER_PORT}
