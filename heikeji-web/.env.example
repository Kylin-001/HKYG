# ============================================
# 黑科易购 (heikeji-web) - 环境变量配置
# 复制此文件为 .env.local 并根据实际环境修改
# ============================================

# 应用基础配置
VITE_APP_TITLE=黑科易购
VITE_APP_DESCRIPTION=黑龙江科技大学校园服务平台
VITE_APP_VERSION=1.0.0

# API配置
VITE_API_BASE_URL=/api
VITE_API_TIMEOUT=30000
VITE_API_RETRY_COUNT=3

# WebSocket配置
VITE_WS_URL=ws://localhost:3000/ws
VITE_WS_RECONNECT_INTERVAL=5000
VITE_WS_HEARTBEAT_INTERVAL=30000

# 功能开关
VITE_ENABLE_MOCK=true
VITE_ENABLE_PWA=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true

# 第三方服务
VITE_SENTRY_DSN=
VITE_GA_TRACKING_ID=

# 高德地图（AMap）配置
# 申请地址: https://console.amap.com/dev/key/app
# 选择 Web端(JSAPI) 类型创建 Key
VITE_AMAP_MAPS_API_KEY=your_amap_key_here

# ============================================
# 以下变量仅在服务器端使用（Docker/CI）
# ============================================

# Node环境
NODE_ENV=production

# 数据库配置
MONGO_URI=mongodb://admin:admin123@mongo:27017/heikeji?authSource=admin
MONGO_DB_NAME=heikeji

# Redis配置
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=redis123

# JWT密钥（生产环境必须修改！）
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# 邮件服务（用于验证码等）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@heikeji.com
SMTP_PASS=your-smtp-password

# 对象存储（用于图片上传）
OSS_ENDPOINT=https://oss-cn-harbin.aliyuncs.com
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=heikeji-uploads

# 日志配置
LOG_LEVEL=info
LOG_MAX_FILES=30
LOG_MAX_SIZE=10m
