{
  "name": "heikeji-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "typecheck": "vue-tsc --noEmit",
    "clean": "rimraf dist coverage node_modules/.vite test-results playwright-report",
    "analyze": "vite build --mode analyze",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "generate": "node scripts/generate.mjs",
    "changelog": "node scripts/changelog.mjs",
    "dev:tools": "node scripts/dev-tools.mjs",
    "dev:health-check": "node scripts/dev-tools.mjs health-check",
    "dev:lint-fix": "node scripts/dev-tools.mjs lint-fix",
    "dev:format-all": "node scripts/dev-tools.mjs format-all",
    "deploy:build": "docker build -t heikeji-web:latest .",
    "deploy:up": "docker compose up -d --build",
    "deploy:down": "docker compose down",
    "deploy:logs": "docker compose logs -f --tail=100",
    "deploy:status": "docker compose ps && docker stats --no-stream",
    "deploy:clean": "docker system prune -f",
    "security:audit": "node scripts/security-audit.mjs",
    "perf:baseline": "node -e \"import('./config/performance.config.js').then(m => console.log(JSON.stringify(m.default, null, 2)))\""
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.14.0",
    "dayjs": "^1.11.20",
    "echarts": "^6.0.0",
    "echarts-for-vue": "^1.4.1",
    "element-plus": "^2.13.6",
    "fuse.js": "^7.3.0",
    "gsap": "^3.14.2",
    "js-cookie": "^3.0.5",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.30",
    "vue-echarts": "^8.0.1",
    "vue-i18n": "^12.0.0-alpha.3",
    "vue-router": "^4.6.4",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^24.12.0",
    "@types/nprogress": "^0.2.3",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "autoprefixer": "^10.4.27",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-n": "^17.15.0",
    "eslint-plugin-promise": "^7.1.0",
    "eslint-plugin-vue": "^9.32.0",
    "happy-dom": "^20.8.9",
    "mockjs": "^1.1.0",
    "playwright": "^1.59.1",
    "postcss": "^8.5.8",
    "prettier": "^3.5.3",
    "sass": "^1.98.0",
    "tailwindcss": "^4.2.2",
    "terser": "^5.46.1",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.1",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-mock": "^3.0.2",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.5"
  }
}
