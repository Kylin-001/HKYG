# 加密配置
# 请在生产环境中使用安全的随机密钥

# 默认加密密钥（用于一般数据加密）
VITE_APP_ENCRYPTION_KEY=default-encryption-key-32-chars-long

# 敏感数据加密密钥（用于密码、令牌等敏感信息）
VITE_APP_SENSITIVE_DATA_KEY=sensitive-data-encryption-key-64-chars-long-and-secure

# 本地存储加密密钥（用于本地存储的数据）
VITE_APP_LOCAL_STORAGE_KEY=local-storage-encryption-key-48-chars-long-and-secure

# API安全配置
# 是否启用请求加密
VITE_APP_ENABLE_REQUEST_ENCRYPTION=true

# 是否启用响应解密
VITE_APP_ENABLE_RESPONSE_DECRYPTION=true

# 是否启用速率限制
VITE_APP_ENABLE_RATE_LIMITING=true

# 速率限制配置（秒）
VITE_APP_RATE_LIMIT_WINDOW=60
VITE_APP_RATE_LIMIT_MAX_REQUESTS=100

# 登录API速率限制配置
VITE_APP_LOGIN_RATE_LIMIT_WINDOW=60
VITE_APP_LOGIN_RATE_LIMIT_MAX_REQUESTS=5

# 注册API速率限制配置
VITE_APP_REGISTER_RATE_LIMIT_WINDOW=3600
VITE_APP_REGISTER_RATE_LIMIT_MAX_REQUESTS=3

# 敏感操作API速率限制配置
VITE_APP_SENSITIVE_RATE_LIMIT_WINDOW=60
VITE_APP_SENSITIVE_RATE_LIMIT_MAX_REQUESTS=10

# 文件上传API速率限制配置
VITE_APP_UPLOAD_RATE_LIMIT_WINDOW=60
VITE_APP_UPLOAD_RATE_LIMIT_MAX_REQUESTS=5

# 搜索API速率限制配置
VITE_APP_SEARCH_RATE_LIMIT_WINDOW=60
VITE_APP_SEARCH_RATE_LIMIT_MAX_REQUESTS=30