{
  "name": "heikeji-campus-service-frontend",
  "version": "1.0.0",
  "description": "黑科易购校园服务平台前端项目",
  "author": "heikeji",
  "private": true,
  "scripts": {
    "dev": "vite",
    "serve": "vite preview",
    "start": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:preview": "vite build --mode preview",
    "build-only": "vite build",
    "type-check": "npx tsc --noEmit",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:watch-real": "node test-watcher.js",
    "test:coverage-history": "node coverage-history.js",
    "test:performance": "node performance-monitor.js",
    "test:performance:ci": "lhci autorun",
    "test:e2e": "npx playwright test",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write \"src/**/*.{vue,js,ts,jsx,tsx,css,scss}\"",
    "format:check": "prettier --check \"src/**/*.{vue,js,ts,jsx,tsx,css,scss}\"",
    "pre-commit": "lint-staged",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "monitor:tests": "node test-watcher.js",
    "monitor:coverage": "node coverage-history.js",
    "monitor:performance": "node performance-monitor.js",
    "schedule:tests": "node scheduled-tests.js",
    "report:generate": "node test-report-generator.js",
    "report:summary": "node test-report-generator.js --summary",
    "test:full": "npm run test:unit && npm run test:coverage && npm run test:performance && npm run test:e2e && npm run report:generate"
  },
  "dependencies": {
    "@babel/runtime": "^7.25.0",
    "@element-plus/icons-vue": "^2.3.2",
    "axios": "^1.6.0",
    "cssnano": "^6.0.0",
    "echarts": "^5.4.0",
    "element-plus": "^2.4.4",
    "express": "^4.18.2",
    "js-cookie": "^3.0.5",
    "normalize.css": "^8.0.1",
    "nprogress": "^0.2.0",
    "pinia": "^2.1.7",
    "vue": "^3.5.1",
    "vue-i18n": "^12.0.0-alpha.3",
    "vue-router": "^4.2.5",
    "vue3-lazyload": "^0.3.8"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/plugin-transform-runtime": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@chromatic-com/storybook": "^4.1.3",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.41.1",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.17",
    "chokidar": "^3.6.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.22.0",
    "husky": "^8.0.3",
    "jsdom": "^22.1.0",
    "lint-staged": "^15.2.0",
    "postcss": "^8.4.33",
    "postcss-pxtorem": "^6.1.0",
    "prettier": "^3.2.5",
    "sass": "^1.71.1",
    "stylelint": "^16.2.1",
    "typescript": "^5.2.2",
    "unplugin-auto-import": "^0.17.5",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^5.0.0",
    "vitest": "^4.0.16"
  }
}
