{
  "name": "heikeji-campus-service-frontend",
  "version": "1.0.0",
  "description": "黑科易购校园服务平台前端项目",
  "author": "heikeji",
  "private": true,
  "scripts": {
    "dev": "vite",
    "serve": "vite preview",
    "start": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:preview": "vite build --mode preview",
    "build-only": "vite build",
    "type-check": "npx tsc --noEmit",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:watch-real": "node test-watcher.js",
    "test:coverage-history": "node coverage-history.js",
    "test:performance": "node performance-monitor.js",
    "test:performance:ci": "lhci autorun",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:debug": "npx playwright test --debug",
    "test:e2e:chrome": "npx playwright test --browser=chromium",
    "test:e2e:firefox": "npx playwright test --browser=firefox",
    "test:e2e:webkit": "npx playwright test --browser=webkit",
    "test:e2e:report": "npx playwright show-report",
    "test:e2e:codegen": "npx playwright codegen",
    "test:e2e:install": "npx playwright install",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write \"src/**/*.{vue,js,ts,jsx,tsx,css,scss}\"",
    "format:check": "prettier --check \"src/**/*.{vue,js,ts,jsx,tsx,css,scss}\"",
    "pre-commit": "lint-staged",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "monitor:tests": "node test-watcher.js",
    "monitor:coverage": "node coverage-history.js",
    "monitor:performance": "node performance-monitor.js",
    "schedule:tests": "node scheduled-tests.js",
    "report:generate": "node test-report-generator.js",
    "report:summary": "node test-report-generator.js --summary",
    "test:full": "npm run test:unit && npm run test:coverage && npm run test:performance && npm run test:e2e && npm run report:generate",
    "test:monitor": "node scripts/test-monitor.js",
    "test:coverage:history": "node scripts/coverage-history.js",
    "test:ci": "npm run test:unit && npm run test:coverage && npm run test:e2e:chrome && npm run test:monitor",
    "security:audit": "node scripts/security-audit.js",
    "security:check": "npm audit && npm run security:audit",
    "security:fix": "npm audit fix && npm run security:audit",
    "lint:security": "eslint --config .eslintrc.security.js src/**/*.{js,ts,vue}",
    "test:security": "vitest run src/api/security.test.ts",
    "security:generate-keys": "node -e \"const crypto = require('crypto'); console.log('VITE_APP_ENCRYPTION_KEY=' + crypto.randomBytes(32).toString('hex')); console.log('VITE_APP_SENSITIVE_DATA_KEY=' + crypto.randomBytes(64).toString('hex')); console.log('VITE_APP_LOCAL_STORAGE_KEY=' + crypto.randomBytes(48).toString('hex'));\"",
    "build:optimized": "vite build --config vite.config.optimized.ts",
    "build:analyze": "vite build --config vite.config.optimized.ts && npx vite-bundle-analyzer dist/stats.json",
    "test:lighthouse": "node scripts/lighthouse.js",
    "test:performance": "node scripts/performance-test.js",
    "report:performance": "node scripts/performance-report.js",
    "optimize:images": "node scripts/image-optimizer.js",
    "optimize:bundle": "node scripts/bundle-optimizer.js",
    "cache:warmup": "node scripts/cache-warmup.js",
    "cache:monitor": "node scripts/cache-monitor.js",
    "cache:analyze": "node scripts/cache-analyze.js",
    "cache:cleanup": "node scripts/cache-cleanup.js",
    "test:cache": "vitest run src/utils/cache-*.test.ts",
    "test:cache:coverage": "vitest run src/utils/cache-*.test.ts --coverage",
    "test:cache:performance": "node scripts/cache-performance-test.js",
    "report:cache": "node scripts/cache-report.js",
    "test:coverage:boost": "node scripts/test-coverage-boost.js",
    "test:coverage:monitor": "node scripts/test-coverage-monitor.js",
    "test:coverage:history": "node scripts/test-coverage-monitor.js",
    "db:analyze": "node scripts/database-optimizer.js",
    "db:optimize": "node scripts/database-optimizer.js && npm run db:apply",
    "db:apply": "node scripts/database-optimizer.js --apply",
    "db:report": "node scripts/database-optimizer.js --report",
    "db:performance:monitor": "node scripts/database-performance-monitor.js",
    "performance:analyze": "node scripts/database-performance-monitor.js",
    "security:audit": "node scripts/security-audit.js",
    "security:report": "node scripts/security-audit.js --report",
    "security:fix": "npm audit fix --force",
    "security:check": "npm audit --audit-level moderate"
  },
  "dependencies": {
    "@babel/runtime": "^7.25.0",
    "@element-plus/icons-vue": "^2.3.2",
    "axios": "^1.6.0",
    "crypto-js": "^4.2.0",
    "cssnano": "^6.0.0",
    "echarts": "^5.4.0",
    "element-plus": "^2.4.4",
    "express": "^4.18.2",
    "js-cookie": "^3.0.5",
    "normalize.css": "^8.0.1",
    "nprogress": "^0.2.0",
    "pinia": "^2.1.7",
    "vue": "^3.5.1",
    "vue-i18n": "^12.0.0-alpha.3",
    "vue-router": "^4.2.5",
    "vue3-lazyload": "^0.3.8"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/plugin-transform-runtime": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@chromatic-com/storybook": "^4.1.3",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.41.1",
    "@types/crypto-js": "^4.2.2",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.17",
    "chokidar": "^3.6.0",
    "eslint": "^8.57.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-vue": "^9.22.0",
    "helmet": "^8.1.0",
    "husky": "^8.0.3",
    "jsdom": "^22.1.0",
    "jsdom-global": "^3.0.2",
    "lint-staged": "^15.2.0",
    "playwright": "^1.41.1",
    "postcss": "^8.4.33",
    "postcss-pxtorem": "^6.1.0",
    "prettier": "^3.2.5",
    "sass": "^1.71.1",
    "stylelint": "^16.2.1",
    "tough-cookie": "^6.0.0",
    "typescript": "^5.2.2",
    "unplugin-auto-import": "^0.17.5",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^5.0.0",
    "vitest": "^4.0.16"
  }
}
